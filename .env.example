# Freelance Lead Gen - Environment Configuration
# Copy this to .env and fill in your values

# LLM Configuration
LLM_PROVIDER=opencode
LLM_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_API_KEY=
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=120

# Browser Configuration
BROWSER_HEADLESS=false
BROWSER_USER_DATA_DIR=./browser_data
BROWSER_VIEWPORT_WIDTH=1920
BROWSER_VIEWPORT_HEIGHT=1080

# Discovery Configuration
# DISCOVERY_SCHEDULE_INTERVAL_MINUTES=360  (default: 360 min = 6 hours)
DISCOVERY_MAX_DAILY=50
DISCOVERY_SEARCH_QUERIES=AI automation,AI readiness assessment,LLM pipeline,fine-tuning,RAG implementation,AI consulting,IT consulting

# Database
DATABASE_PATH=./data/leads.db
# DATABASE_ECHO=false
# DATABASE_POOL_SIZE=5
# DATABASE_POOL_OVERFLOW=10

# Platform Credentials
# The system logs in to these platforms to discover opportunities.
# Create free accounts and fill in your credentials below.
# These are stored locally in .env and used only by the browser automation.
#
# Upwork — https://www.upwork.com
UPWORK_USERNAME=
UPWORK_PASSWORD=
#
# LinkedIn — https://www.linkedin.com
LINKEDIN_USERNAME=
LINKEDIN_PASSWORD=
#
# Freelancer — https://www.freelancer.com
FREELANCER_USERNAME=
FREELANCER_PASSWORD=

# HITL Configuration
HITL_ENABLED=true
HITL_AUTO_APPROVE=false
# HITL_REVIEW_TIMEOUT_SECONDS=86400  (default: 24 hours)

# Platform Enablement
PLATFORMS_ENABLED=upwork,linkedin,freelancer
